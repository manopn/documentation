  "keyFeatures": [
    "PIX instant payment generation (EMV QR Code + copy-paste)",
    "Boleto banking slip issuance with PDF",
    "Credit card processing with installments (Visa, Mastercard, Elo)",
    "Card tokenization for recurring charges",
    "Full and partial refunds",
    "Webhook notifications for all transaction lifecycle events",
    "Idempotency support to prevent duplicate charges",
    "API Key authentication with rate limiting"
  ],
  "publicApiSurface": [
    "POST /api/customers",
    "GET /api/customers",
    "GET /api/customers/{id}",
    "PATCH /api/customers/{id}",
    "DELETE /api/customers/{id}",
    "POST /api/orders",
    "GET /api/orders",
    "GET /api/orders/{id}",
    "POST /api/payment-gateway/process",
    "POST /api/payment-gateway/tokenize-card",
    "POST /api/payment-gateway/refund",
    "GET /api/transactions",
    "GET /api/transactions/{transactionId}",
    "GET /api/transaction-events/transaction/{transactionId}",
    "POST /api/webhooks/upsert",
    "GET /api/webhooks",
    "DELETE /api/webhooks",
    "GET /api/webhooks/deliveries",
    "POST /api/webhooks/deliveries/{deliveryId}/retry",
    "GET /api/api-keys/me",
    "POST /api/api-keys/me/regenerate"
  ]
}
